# Virtual environments
.venv/

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Editor directories
.vscode/
.idea/

# Env files
.env

# Misc
.DS_Store
node_modules/
dist/

# Training run logs
*.log

# AZ training artifacts (checkpoints, replay buffer) — az_model.npz ships separately
games/spender/ai/az/checkpoints/
games/spender/ai/az/checkpoints*/

# AZ offline-tooling scratch outputs (regenerated by the h3_*/s_measure/turns_ab harnesses)
games/spender/ai/az/*.out
games/spender/ai/az/turns_table_s.json

# net-retrain investigation scratch (harvested caches + fitted leaf model; regenerable)
games/spender/ai/az/*cache*.npz
games/spender/ai/az/leaf_model.npz

# SQLite databases (contain user data)
*.db

# Cython build artifacts — the hot-path module (valuation3) is compiled in the Docker build, never committed
games/spender/ai/az/valuation3.c
games/spender/ai/az/*.so
games/spender/ai/az/*.pyd
# MSVC byproducts of a local in-place `cythonize -i` build (dev box now has a compiler)
games/spender/ai/az/*.obj
games/spender/ai/az/*.exp
games/spender/ai/az/*.lib

# Cython/setuptools build temp dir
build/
